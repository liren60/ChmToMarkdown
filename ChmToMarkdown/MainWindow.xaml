<Window x:Class="ChmToMarkdown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChmToMarkdown"
        mc:Ignorable="d"
        Title="CHM 转 Markdown" Height="620" Width="880"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:PercentToWidthConverter x:Key="PctToWidth"/>
        <local:ContinueTextConverter x:Key="ContinueTextConv"/>

        <!-- 卡片样式 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主按钮 -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次要按钮 -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 绿色成功按钮 -->
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#16A34A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15803D"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#86EFAC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 路径输入框 -->
        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 标签 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="CHM" FontSize="22" FontWeight="Bold" Foreground="#2563EB"/>
            <TextBlock Text=" 转 Markdown" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
            <Border Background="#DBEAFE" CornerRadius="4" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="CHM → MD" FontSize="11" Foreground="#2563EB" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>

        <!-- 文件选择卡片 -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- CHM 文件 -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="CHM 文件" Style="{StaticResource FieldLabel}"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource PathBox}"
                                 Text="{Binding ChmPath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" AllowDrop="True"
                                 PreviewDrop="ChmPath_Drop" PreviewDragOver="File_DragOver"/>
                        <Button Grid.Column="2" Content="选择文件" Style="{StaticResource SecondaryBtn}" Click="BrowseChm_Click"/>
                    </Grid>
                </Grid>

                <!-- 输出目录 -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="输出目录" Style="{StaticResource FieldLabel}"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource PathBox}"
                                 Text="{Binding OutputDir, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" AllowDrop="True"
                                 PreviewDrop="OutputDir_Drop" PreviewDragOver="File_DragOver"/>
                        <Button Grid.Column="2" Content="选择目录" Style="{StaticResource SecondaryBtn}" Click="BrowseOutput_Click"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- 步骤 & 模式卡片 -->
        <Border Grid.Row="4" Style="{StaticResource Card}">
            <StackPanel>
                <!-- 未完成任务提示横幅 -->
                <Border Background="#FEF9C3" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                        Visibility="{Binding HasUnfinishedTask, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="检测到上次未完成的转换任务，点击【继续转换】从断点继续。"
                                   FontSize="12" Foreground="#92400E" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 步骤按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- 步骤1 -->
                        <Grid Margin="0,0,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="步骤 1" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Button Grid.Row="2" Content="{Binding ExtractButtonText}" Width="160"
                                    Style="{StaticResource PrimaryBtn}" IsEnabled="{Binding CanExtract}"
                                    Click="Extract_Click"/>
                            <!-- Spinner -->
                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center"
                                        Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVis}}">
                                <Ellipse Width="16" Height="16" Margin="0,0,6,0">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate" CenterX="8" CenterY="8"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2563EB" Offset="0"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="正在解压..." FontSize="11" Foreground="#2563EB" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- 箭头 -->
                        <TextBlock Text="›" FontSize="24" Foreground="#CBD5E1" VerticalAlignment="Bottom" Margin="0,0,10,6"/>

                        <!-- 步骤2 -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="步骤 2" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Button Grid.Row="2" Content="{Binding HasUnfinishedTask, Converter={StaticResource ContinueTextConv}}"
                                    Width="160" Style="{StaticResource SuccessBtn}" IsEnabled="{Binding CanConvert}"
                                    Click="Convert_Click"/>
                            <!-- 转换进度文字 -->
                            <TextBlock Grid.Row="4" Text="{Binding ProgressText}"
                                       HorizontalAlignment="Center" FontSize="11" Foreground="#16A34A"
                                       FontWeight="SemiBold"
                                       Visibility="{Binding IsConverting, Converter={StaticResource BoolToVis}}"/>
                        </Grid>

                        <!-- 箭头 -->
                        <TextBlock Text="›" FontSize="24" Foreground="#CBD5E1" VerticalAlignment="Bottom" Margin="10,0,10,6"/>

                        <!-- 取消按钮 -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="取消" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                            <Button Grid.Row="2" Content="⏹ 中止" Width="100"
                                    IsEnabled="{Binding CanCancel}" Click="Cancel_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
                                        <Setter Property="Foreground" Value="#DC2626"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- 分隔线 -->
                    <Rectangle Grid.Column="1" Width="1" Fill="#E2E8F0" VerticalAlignment="Stretch"/>

                    <!-- 输出模式 -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="输出模式" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                        <RadioButton Content="多文件（每页独立 .md）"
                                     IsChecked="{Binding IsMultiFile}"
                                     FontSize="13" Foreground="#374151" Margin="0,0,0,6"/>
                        <RadioButton Content="单文件（合并为 output.md）"
                                     IsChecked="{Binding IsMultiFile, Converter={StaticResource InverseBool}}"
                                     FontSize="13" Foreground="#374151"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>


        <!-- 日志卡片 -->
        <Border Grid.Row="6" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 日志标题栏 -->
                <Grid Grid.Row="0" Background="#F8FAFC" Margin="0">
                    <Border CornerRadius="8,8,0,0" Background="#F8FAFC">
                        <Grid Margin="14,10,14,10">
                            <TextBlock Text="运行日志" FontSize="12" FontWeight="SemiBold" Foreground="#6B7280" VerticalAlignment="Center"/>
                            <Button Content="清空" HorizontalAlignment="Right" Click="ClearLog_Click"
                                    Style="{StaticResource SecondaryBtn}" Padding="10,4" FontSize="12"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 日志内容 -->
                <TextBox Grid.Row="1" x:Name="LogBox"
                         Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="12" Foreground="#1E293B"
                         Background="White"
                         BorderThickness="0,1,0,0" BorderBrush="#F1F5F9"
                         Padding="14,10" TextWrapping="NoWrap"/>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="12,6" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="#000000"/>
                </Border.Effect>
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="12,6" MinWidth="160">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="#000000"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="#6B7280"
                               VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="30"
                               HorizontalAlignment="Right"/>
                    <Grid Width="120" Height="8">
                        <Border CornerRadius="4" Background="#F1F5F9"/>
                        <Grid HorizontalAlignment="Left"
                              Width="{Binding Progress, Converter={StaticResource PctToWidth}}">
                            <Border x:Name="ProgressFill" CornerRadius="4" Background="#2563EB"/>
                            <!-- 光晕层 -->
                            <Border x:Name="ProgressGlow" CornerRadius="4" Opacity="0"
                                    Visibility="{Binding IsConverting, Converter={StaticResource BoolToVis}}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#60A5FA" Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
